{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.1",
            "config": {
                "command": "rm -rf bootstrap/cache/*.php && composer install --no-dev --optimize-autoloader"
            }
        }
    ],
    "routes": [
        {
            "src": "/src/(.*)",
            "dest": "/public/src/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}