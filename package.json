{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.1",
            "config": {
                "phpVersion": "8.3",
                "composerEnv": {
                    "COMPOSER_AUTH": "{}",
                    "COMPOSER_ALLOW_SUPERUSER": "1"
                }
            }
        }
    ],
    "routes": [
        {
            "src": "/src/(.*)",
            "dest": "/public/src/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/index.php"
        }
    ]
}